# Copy this file to .env and fill in your details

# Gmail address you'll send FROM (must be a Gmail account)
EMAIL_USER=you@gmail.com

# Gmail App Password (NOT your normal password)
# Go to: Google Account → Security → 2-Step Verification → App Passwords
# Create one for "Mail" and paste it here
EMAIL_PASS=xxxx xxxx xxxx xxxx

# The email address quotes get SENT TO (your business inbox)
BUSINESS_EMAIL=zyntrixautomation@gmail.com

# Server port (leave as 3000 unless something else is using it)
PORT=3000
