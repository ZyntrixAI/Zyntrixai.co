# Claude API Key for AI automation features
# Get from: https://console.anthropic.com/api-keys
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxx

# Server port (leave as 3000 unless something else is using it)
PORT=3000
