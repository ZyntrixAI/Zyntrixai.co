{
  "version": 2,
  "env": {
    "BUILD_ID": "2026-06-16-latest"
  },
  "routes": [
    {
      "src": "/crm",
      "dest": "/crm.html"
    },
    {
      "src": "/portal",
      "dest": "/client-portal.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=0, must-revalidate"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        }
      ]
    }
  ]
}
