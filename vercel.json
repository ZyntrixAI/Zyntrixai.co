{
  "version": 2,
  "env": {
    "BUILD_ID": "2026-06-16-rebuild-website",
    "DEPLOYMENT_TIMESTAMP": "20260616-204200"
  },
  "routes": [
    {
      "src": "/crm",
      "dest": "/crm.html"
    },
    {
      "src": "/portal",
      "dest": "/client-portal.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate, max-age=0"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        }
      ]
    }
  ]
}
